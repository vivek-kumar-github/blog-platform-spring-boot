# Allow the Maven Wrapper JAR to be committed so the app can build anywhere
!**/.mvn/wrapper/maven-wrapper.jar

# Ignore nested target/build folders if they appear, but keep source code intact
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

